echo ~/bin/bashrc START `date +"%Y%m%d@%H%M%S.%3N"`

RED="\[\033[1;31m\]"; BYELLOW="\[\033[1;33m\]"; YELLOW="\[\033[0;33m\]"; GREEN="\[\033[0;32m\]"; NO_COLOR="\[\033[0m\]"

function git_dirty1 {
  [[ $(git status 2> /dev/null | tail -n1 | sed s/,.*// ) != "nothing to commit" ]] && echo "*"
}
#function parse_git_branch {
#    git branch --no-color 2> /dev/null | sed -e '/^[^*]/d' -e "s/* \(.*\)/[\1$(git_dirty)]/"
#}

function git_dirty2 () {
  if [ -n "$(git status --porcelain 2>/dev/null)" ]; then echo -n "$BYELLOW*"; else echo -n "$YELLOW";fi
}

function PSGIT () {
  git branch 2>/dev/null | sed -e '/^[^*]/d' -e 's/* \(.*\)/\1/' 
}

function job_count () {
  jobs | wc -l | sed -e 's/ *//'
}

function user_color () {
  [ "$EUID" -eq 0 ] && echo -n $RED || echo -n $GREEN
}

function PSVENV () {
  echo -n $(basename "$VIRTUAL_ENV")
} 

dynamic_prompt () {
  PS1="$(user_color)${HOSTNAME:0:3}:$YELLOW$(git_dirty2)$(PSGIT):\W:$(PSVENV)$NO_COLOR:$(job_count)> "
}
#following is required for MacOS bash:
PROMPT_COMMAND=dynamic_prompt

function rgg() {
  dir=$1
  shift
  rg --iglob=${dir}/** $@
}

